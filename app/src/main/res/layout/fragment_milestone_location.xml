<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MILESTONE MAP -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map_milestone_showing"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.65"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:liteMode="true"
        tools:layout="@layout/map_example" />

    <!-- PERFORM LOCATION BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_setting_milestone"
        style="@style/Button_teacher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/set_position"
        app:icon="@drawable/icon_milestone"
        app:layout_constraintTop_toBottomOf="@id/map_milestone_showing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>