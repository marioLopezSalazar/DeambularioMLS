<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:maxWidth="520dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <!-- DRAG HANDLE -->
        <View
            android:id="@+id/test_stud_drag_handle"
            style="@style/BottomSheet_Handle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- QUESTION -->
        <TextView
            android:id="@+id/textview_stud_test_question"
            style="@style/Subtitle_student"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/test_stud_drag_handle"
            tools:ignore="TextContrastCheck"
            tools:text="Which of these animals cannot fly?" />

        <!-- TEST OPTIONS-->
        <RadioGroup
            android:id="@+id/radio_group_stud_test_options"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textview_stud_test_question">
        </RadioGroup>

        <!-- SUBMIT TEST -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_stud_submit_test"
            style="@style/Button_student"
            app:icon="@drawable/icon_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/ok"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/radio_group_stud_test_options" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>