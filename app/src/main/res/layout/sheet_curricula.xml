<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- BOTTOM SHEET HANDLE -->
    <View style="@style/BottomSheet_Handle" />

    <!-- CURRICULA TITLE -->
    <TextView
        style="@style/Title_teacher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/curricula" />

    <!-- CURRICULA DETAILS -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/bottom_sheet_text_curricula"
            style="@style/Text_teacher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Route designed to learn about forests pollution.\nSDG 6, 11,12.\nTime estimated on development: 1:30h."/>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>