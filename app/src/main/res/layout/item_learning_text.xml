<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Card_student"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp">

    <!-- TEXT CONTAINER -->
    <TextView
        android:id="@+id/textview_content_text"
        style="@style/Text_student"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:textColor="?attr/colorOnSurface"
        tools:text="Each April, the National Park Service celebrates National Volunteer Month by recognizing the contributions of our volunteers."
        tools:ignore="VisualLintLongText" />

</com.google.android.material.card.MaterialCardView>