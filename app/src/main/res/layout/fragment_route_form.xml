<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:id="@+id/route_form_scroll"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ROUTE TITLE -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_title"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:hint="@string/title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/text_input_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                tools:ignore="TextContrastCheck" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ROUTE EDUCATIVE LEVEL -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_course"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:hint="@string/educative_level"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/input_title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/text_input_course"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                tools:ignore="TextContrastCheck" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ROUTE MAP -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/route_map_form"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/input_course"
            tools:layout="@layout/map_example" />

        <!-- ADD MILESTONE BUTTON -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/button_add_milestone"
            style="@style/Fab_teacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/add_milestone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/route_map_form"
            app:srcCompat="@drawable/icon_add"
            tools:ignore="ClassNameCheck" />

        <!-- ROUTE IN ORDER SWITCH -->
        <TextView
            android:id="@+id/text_order"
            style="@style/SwitchLabel_teacher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="@string/ordered_milestones"
            app:layout_constraintBottom_toBottomOf="@+id/button_add_milestone"
            app:layout_constraintEnd_toStartOf="@+id/switch_inorder"
            app:layout_constraintStart_toEndOf="@+id/button_add_milestone"
            app:layout_constraintTop_toTopOf="@+id/button_add_milestone" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_inorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@+id/button_add_milestone"
            android:contentDescription="@string/in_order"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/button_add_milestone" />

        <!-- MILESTONES RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_milestones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/button_add_milestone"
            tools:itemCount="2"
            tools:listitem="@layout/item_milestone" />

        <!-- SET UP GEOFENCE BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_geofence"
            style="@style/Button_teacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="@string/set_up_geofence"
            app:icon="@drawable/icon_geofence"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/recyclerview_milestones" />

        <!-- ENABLE GEOFENCE SWITCH -->
        <TextView
            android:id="@+id/text_geofence_active"
            style="@style/SwitchLabel_teacher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="@string/active_geofence"
            app:layout_constraintBottom_toBottomOf="@+id/button_geofence"
            app:layout_constraintEnd_toStartOf="@+id/switch_geofence"
            app:layout_constraintStart_toEndOf="@+id/button_geofence"
            app:layout_constraintTop_toTopOf="@+id/button_geofence" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_geofence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@+id/button_geofence"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/button_geofence" />

        <!-- ROUTE CURRICULA -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_curricular"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:hint="@string/curricula"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/button_geofence">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/text_input_curricular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:lines="4"
                tools:ignore="TextContrastCheck" />
        </com.google.android.material.textfield.TextInputLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>